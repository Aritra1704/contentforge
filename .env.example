# Optional: set this to enable the Groq backend in compare requests.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local Ollama server and chat models used by the generation endpoints.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_QWEN25_MODEL=qwen2.5:7b-instruct
OLLAMA_LLAMA31_MODEL=llama3.1:8b
OLLAMA_MISTRAL_MODEL=mistral:7b

# Installed locally but not used by the current /generate endpoints.
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

DB_URL=sqlite+aiosqlite:///./llm_comparator.db
