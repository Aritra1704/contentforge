# Optional: enable the secondary Groq backend.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Service metadata shown by /health.
SERVICE_VERSION=dev
LOG_LEVEL=INFO

# Local Ollama server and known model families.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODELS=mistral:7b,qwen2.5:7b-instruct,llama3.1:8b
OLLAMA_EMBEDDING_MODELS=nomic-embed-text:latest

# In-memory admission control for generation jobs.
MAX_CONCURRENT_JOBS=1
MAX_QUEUE=0
BUSY_RETRY_AFTER_MS=2000
REQUEST_TIMEOUT_SEC=120
